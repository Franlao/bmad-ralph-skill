{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"__BR_HOOKS_DIR__/br-guard.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"__BR_HOOKS_DIR__/br-post-edit.sh\""
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"__BR_HOOKS_DIR__/br-monitor.sh\""
          }
        ]
      }
    ]
  }
}
